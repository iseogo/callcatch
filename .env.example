# CallCatch environment variables
# Copy to .env.local and fill in values. Set MOCK_MODE=true for local testing without real accounts.

# --- Core ---
# Prisma CLI reads .env; Next.js reads .env.local — keep DATABASE_URL in both.
# Transaction pooler (app runtime, port 6543):
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session/direct pooler (migrations, port 5432):
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MOCK_MODE="true"
SKIP_ENV_VALIDATION="true"

# --- Retell AI (https://dashboard.retellai.com/) ---
RETELL_API_KEY="retell_api_key_placeholder"

# --- SignalWire (https://signalwire.com/signin) ---
SIGNALWIRE_PROJECT_ID="your_project_id"
SIGNALWIRE_API_TOKEN="your_api_token"
SIGNALWIRE_SPACE_URL="https://your-space.signalwire.com"

# SIP trunk credentials for Retell import-phone-number
SIGNALWIRE_SIP_TERMINATION_URI="your-space.pstn.signalwire.com"
SIGNALWIRE_SIP_USERNAME="sip_username"
SIGNALWIRE_SIP_PASSWORD="sip_password"

# --- Google Calendar (https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# --- Internal API protection ---
PROVISIONING_SECRET="dev_provisioning_secret_change_me"
